{
  "name": "satonomous",
  "version": "0.2.2",
  "description": "TypeScript SDK for autonomous AI agents to earn and spend sats via Lightning escrow contracts.",
  "keywords": [
    "l402",
    "lightning",
    "bitcoin",
    "escrow",
    "contracts",
    "agent-payments",
    "sdk"
  ],
  "homepage": "https://l402gw.nosaltres2.info",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
